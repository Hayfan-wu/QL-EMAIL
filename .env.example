# ============================================
# 网易邮箱大师自动签到 - 环境变量配置
# 复制此文件为 .env 并修改，或发送 大师登录 通过QQ配置
# ============================================

# ---------- 大师号认证（推荐使用 MASTER_COOKIE 一条配置）----------
# 格式: mastersess:::masterfp:::M_INFO:::token1&token2:::email1@163.com&email2@163.com
# 多账号用换行分隔（每行一个 MASTER_COOKIE）
# 获取方式: 用抓包工具抓取 MailMaster App 请求 dashi.163.com
MASTER_COOKIE=

# ---------- 分开配置（可选，与 MASTER_COOKIE 二选一）----------
# MASTER_MASTERSESS=
# MASTER_MASTERFP=
# MASTER_M_INFO=
# MASTER_TOKENS=token1&token2
# MASTER_EMAILS=email1@163.com&email2@163.com

# ---------- 青龙面板 ----------
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- 功能开关 ----------
MASTER_ENABLE_SIGNIN=true
MASTER_ENABLE_TASKS=true
MASTER_ENABLE_AD=true
