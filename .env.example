# ============================================
# 网易邮箱大师自动签到 - 环境变量配置
# ============================================
# 用户只需配置以下三项青龙面板参数，其余由 QQ机器人自动管理
# 在 QQ 群发送 "大师登录" 即可手机号+验证码自动完成所有配置

# ---------- 青龙面板（用户需手动配置这三项）----------
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- 大师号认证（由 大师登录 自动生成，无需手动填写）----------
# 格式: mastersess:::masterfp:::M_INFO:::token1&token2:::email1@163.com
MASTER_COOKIE=

# ---------- 登录手机号（自动记录）----------
MASTER_PHONE=

# ---------- 功能开关 ----------
MASTER_ENABLE_SIGNIN=true
MASTER_ENABLE_TASKS=true
MASTER_ENABLE_AD=true

# ---------- 登录API端点（可选，默认使用网易通行证，抓包后可覆盖）----------
# MASTER_SEND_SMS_URL=https://reg.163.com/interfaces/yd/getSmsCode.do
# MASTER_VERIFY_LOGIN_URL=https://reg.163.com/interfaces/yd/web/login.do
